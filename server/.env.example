# Server
PORT=4000
NODE_ENV=development

# Database (matches docker-compose.yml defaults)
DB_HOST=localhost
DB_PORT=5432
DB_NAME=ete_db
DB_USER=ete_user
DB_PASSWORD=ete_password

# Auth
JWT_SECRET=change-me-to-a-long-random-secret
JWT_EXPIRES_IN=1d

# Frontend origin allowed by CORS
CLIENT_ORIGIN=http://localhost:5173
